#!/usr/bin/env bash
# metals-setup-project — bootstrap metals-lsp for an sbt workspace.
#
# Runs `sbt bloopInstall` to generate .bloop/ config files ahead of time,
# so metals can cold-start without hitting the "New sbt workspace detected,
# would you like to import the build?" prompt (which Claude Code's LSP
# client cannot answer because it doesn't implement window/showMessageRequest).
#
# Run from a directory containing build.sbt. Idempotent — safe to re-run.
# For multi-project builds with external ProjectRefs, run once per
# sub-project directory (the /metals-setup slash command walks the agent
# through this).

set -euo pipefail

log() { printf '[metals-setup-project] %s\n' "$*" >&2; }
die() { log "error: $*"; exit 1; }

# Pinned to match the bloop version metals 1.6.x ships with.
# Bump if you upgrade metals and see bloop version mismatch warnings.
SBT_BLOOP_VERSION="${METALS_SBT_BLOOP_VERSION:-2.0.19}"

[ -f build.sbt ] || die "no build.sbt in $(pwd) — run from a directory containing an sbt build"

command -v sbt >/dev/null 2>&1 || die "sbt not found on PATH — install via 'cs install sbt'"

mkdir -p project

METALS_SBT="project/metals.sbt"
if [ -f "$METALS_SBT" ]; then
  log "$METALS_SBT already present, leaving it alone"
else
  log "writing $METALS_SBT (sbt-bloop $SBT_BLOOP_VERSION)"
  cat > "$METALS_SBT" <<EOF
// Auto-generated by metals-setup-project.
// Enables sbt-bloop so bloopInstall can export build info for metals.
addSbtPlugin("ch.epfl.scala" % "sbt-bloop" % "$SBT_BLOOP_VERSION")
EOF
fi

if [ -d .bloop ] && find .bloop -maxdepth 1 -name '*.json' -type f -print -quit | grep -q .; then
  COUNT=$(find .bloop -maxdepth 1 -name '*.json' -type f | wc -l)
  log ".bloop/ already populated ($COUNT json files) — nothing to do"
  log "(to force regeneration: rm -rf .bloop && metals-setup-project)"
  exit 0
fi

SBT_LOG="/tmp/metals-setup-project-sbt-$$.log"
log "running 'sbt bloopInstall' — this can take 30s–3min on first run"
log "  output tee'd to $SBT_LOG"

if ! sbt bloopInstall 2>&1 | tee "$SBT_LOG"; then
  die "sbt bloopInstall failed — see $SBT_LOG for details"
fi

[ -d .bloop ] || die "sbt bloopInstall completed but .bloop/ was not created"

COUNT=$(find .bloop -maxdepth 1 -name '*.json' -type f | wc -l)
[ "$COUNT" -gt 0 ] || die ".bloop/ exists but contains no json files"

log "success: $COUNT bloop config files generated in .bloop/"
log "metals can now start cleanly on this workspace"
rm -f "$SBT_LOG"
